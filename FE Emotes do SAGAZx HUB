-- AUTO LOAD INICIAL ⭐
--------------------------------------------------

local function InitialLoad()

	task.spawn(function()

		repeat task.wait() until Frame

		local pages = 0

		while pages < 200 do -- quantidade inicial

			LoadMore()

			pages += 1

			task.wait(0.2)

		end

	end)

end

