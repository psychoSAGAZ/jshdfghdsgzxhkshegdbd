local Favorites = {}

local function ReorderEmotes()

	local FavOrder = 0
	local NormalOrder = 10000

	for _,obj in ipairs(Frame:GetChildren()) do

		if obj:IsA("ImageButton") then

			if Favorites[obj.Name] then
				FavOrder += 1
				obj.LayoutOrder = FavOrder
			else
				NormalOrder += 1
				obj.LayoutOrder = NormalOrder
			end

		end

	end

end

