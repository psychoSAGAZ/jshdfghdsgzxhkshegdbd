local function UpdateSearch()

	local Texto = string.lower(SearchBar.Text)

	for _,obj in ipairs(Frame:GetChildren()) do

		if obj:IsA("ImageButton") then

			local Nome =
				string.lower(
					obj:GetAttribute("EmoteName") or ""
				)

			local Id = obj.Name

			if Texto == "" then

				obj.Visible = true

			elseif string.find(Nome, Texto, 1, true) then

				obj.Visible = true

			elseif string.find(Id, Texto, 1, true) then

				obj.Visible = true

			else

				obj.Visible = false

			end

		end

	end

end

SearchBar:GetPropertyChangedSignal("Text"):Connect(UpdateSearch)

