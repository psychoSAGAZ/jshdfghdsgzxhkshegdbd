local function LoadMore()

	if loading then return end
	if TotalLoaded >= MaxEmotes then return end

	loading = true

	local url =
		"https://catalog.roblox.com/v1/search/items/details?Category=12&Subcategory=39&Limit=30&Cursor="
		.. cursor

	local success,response = pcall(function()
		return game:HttpGet(url)
	end)

	if success and response then

		local data = HttpService:JSONDecode(response)

		if data and data.data then

			for _,emote in ipairs(data.data) do

				if TotalLoaded >= MaxEmotes then
					break
				end

				CreateEmote(emote)
			end

			if data.nextPageCursor then
				cursor = data.nextPageCursor
			end
		end
	end

	loading = false
end

task.spawn(function()

	while TotalLoaded < MaxEmotes do
		LoadMore()
		task.wait(0.1)
	end

	print("1500 emotes carregados.")

end)

