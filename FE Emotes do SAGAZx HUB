local function UpdateSearch()



	local text = string.lower(SearchBar.Text)

	for _,obj in ipairs(Frame:GetChildren()) do
		if obj:IsA("ImageButton") then

			local name = string.lower(obj:GetAttribute("EmoteName") or "")
			local id = obj.Name

			-- vazio = mostrar tudo
			if text == "" then
				obj.Visible = true

			-- pesquisar por ID
			elseif string.find(id, text) then
				obj.Visible = true

			-- pesquisar por nome
			elseif string.find(name, text) then
				obj.Visible = true
			else
				obj.Visible = false
			end
		end
	end
end

SearchBar:GetPropertyChangedSignal("Text"):Connect(UpdateSearch)

