--------------------------------------------------
-- LOAD CATALOGO REAL (MULTI SEARCH)
--------------------------------------------------

local SortTypes = {
	0, -- Relevance
	3, -- Updated
	4, -- Created
}

local sortIndex = 1

local function LoadMore()

	if loading then return end
	if not SortTypes[sortIndex] then return end

	loading = true

	local url =
	"https://catalog.roblox.com/v1/search/items/details?Category=12&Subcategory=39&Limit=30&SortType="
	..SortTypes[sortIndex]
	.."&Cursor="..cursor

	local success,response = pcall(function()
		return game:HttpGet(url)
	end)

	if success and response then

		local data = HttpService:JSONDecode(response)

		if data and data.data then

			for _,emote in ipairs(data.data) do
				CreateEmote(emote)
			end

			-- ⭐ FORÇA ATUALIZAÇÃO DO GRID
			task.defer(function()
				RefreshLayout()
				UpdateSearch()
				ReorderEmotes()
			end)

			if data.nextPageCursor then
				cursor = data.nextPageCursor
			else
				sortIndex += 1
				cursor = ""
			end
		end
	end

	loading = false
end

task.spawn(function()

	while SortTypes[sortIndex] do
		LoadMore()
		task.wait(0.15)
	end

end)

